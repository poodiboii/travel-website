# Frontend environment variables (CRA)
# Copy to .env (same folder as package.json) if you want to override defaults.

# Payment mode:
# - mock: do NOT hit CC Avenue; simulate success/failure for UI testing
# - live: force live CC Avenue
# If unset: mock is enabled in development, live in production builds.
REACT_APP_PAYMENT_MODE=mock

# URL of your backend API (where Express + Supabase lives)
# Example: http://localhost:5000
REACT_APP_API_URL=http://localhost:5000
