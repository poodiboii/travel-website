# Server environment variables (Express + Supabase)
# Copy this file to server/.env and update values.

# Supabase credentials (from your Supabase project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# URL of the frontend app (used for redirecting after payments)
FRONTEND_BASE_URL=http://localhost:3000

# Use this to change the server port
PORT=5000
