generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  id        Int      @id @default(autoincrement())
  orderId   String   @unique
  amount    Float
  status    String
  createdAt DateTime @default(now())
  // Add more later if needed, e.g.
  // paymentMode String?
  // userId      String?
}